<div class="max-w-4xl mx-auto p-6" dir="rtl">
  <h1 class="text-2xl font-bold mb-2">כלים מתקדמים</h1>
  <p class="text-gray-500 mb-8">כלי ניפוי שגיאות ופעולות מערכת</p>

  <% if notice.present? %>
    <div class="mb-4 rounded-md bg-green-50 border border-green-200 p-4 text-green-800">
      <%= notice %>
    </div>
  <% end %>

  <% if alert.present? %>
    <div class="mb-4 rounded-md bg-red-50 border border-red-200 p-4 text-red-800">
      <%= alert %>
    </div>
  <% end %>

  <div class="space-y-6">
    <!-- Run Daily Scheduler -->
    <section class="bg-white border border-gray-200 rounded-lg p-6">
      <h2 class="text-lg font-semibold mb-1">הרצת מתזמן יומי לקהילה</h2>
      <p class="text-sm text-gray-500 mb-4">
        מריץ את <code>FutureMessageCommunityDailySchedulerJob</code> כולל שחזור הודעות שלא נשלחו,
        ואחר כך שולח הודעות שתאריך השליחה שלהן הוא היום.
      </p>
      <%= form_with url: run_scheduler_hke_admin_advanced_path, method: :post, local: true do |f| %>
        <div class="flex items-center gap-3">
          <%= f.select :community_id,
            options_from_collection_for_select(@communities, :id, :name),
            { prompt: "בחר קהילה..." },
            { class: "rounded-md border px-3 py-2 w-64", dir: "rtl" } %>
          <%= f.submit "הרץ עכשיו",
            class: "rounded-md bg-blue-600 px-4 py-2 text-white hover:bg-blue-700 cursor-pointer",
            data: { turbo_confirm: "להריץ את המתזמן היומי עבור הקהילה הנבחרת?" } %>
        </div>
      <% end %>
    </section>

    <!-- Run Past-Due Recovery -->
    <section class="bg-white border border-gray-200 rounded-lg p-6">
      <h2 class="text-lg font-semibold mb-1">שחזור הודעות שלא נשלחו בזמן</h2>
      <p class="text-sm text-gray-500 mb-4">
        מריץ את <code>FutureMessagePastDueRecoveryJob</code> — מטפל בהודעות שתאריך השליחה שלהן עבר:
        ארכיב הודעות שהיארצייט כבר חלף, ותזמון מחדש של הודעות שעדיין ניתן לשלוח.
      </p>
      <%= form_with url: run_recovery_hke_admin_advanced_path, method: :post, local: true do |f| %>
        <div class="flex items-center gap-3">
          <%= f.select :community_id,
            options_from_collection_for_select(@communities, :id, :name),
            { prompt: "בחר קהילה..." },
            { class: "rounded-md border px-3 py-2 w-64", dir: "rtl" } %>
          <%= f.submit "הרץ עכשיו",
            class: "rounded-md bg-orange-600 px-4 py-2 text-white hover:bg-orange-700 cursor-pointer",
            data: { turbo_confirm: "להריץ שחזור הודעות עבור הקהילה הנבחרת?" } %>
        </div>
      <% end %>
    </section>
  </div>
</div>
