<div class="flex items-center justify-between mb-4 h4">
  <% if community.persisted? %>
    <%= t("admin.communities.edit.title") + ": #{community.name}" %>
  <% else %>
    <%= t("admin.communities.new.title") %>
  <% end %>
  <div class="mr-auto flex">
    <%= link_to t("cancel"), hke_admin_communities_path, class: "btn btn-link" %>
  </div>
</div>

<%= form_with(model: community,
      url: community.persisted? ? hke_admin_community_path(community) : hke_admin_communities_path,
      method: community.persisted? ? :patch : :post,
      multipart: true,
      data: { turbo: false }) do |form| %>
  <%= render "shared/error_messages", resource: form.object %>

  <div class="mr-auto flex mb-4">
    <%= form.button t('save'), class: "btn btn-link" %>
    <% if form.object.persisted? %>
      <%= link_to t("delete"), hke_admin_community_path(form.object), class: "btn btn-link", data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") } %>
    <% end %>
  </div>

  <%= render "community_fields", form: form %>

<% end %>
