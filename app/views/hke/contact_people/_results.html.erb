<div class="adm-results-info">
  <% if params[:name_search].present? %>
    מציג <%= pagy.count %> מתוך <%= total_contacts %> אנשי קשר
  <% else %>
    <%= total_contacts %> אנשי קשר סך הכל
  <% end %>
</div>

<div class="adm-fleet-card">
  <% if contact_people.any? %>
    <table class="adm-fleet">
      <thead>
        <tr>
          <th><%= sortable contact_people, :first_name, t(:first_name) %></th>
          <th><%= sortable contact_people, :last_name, t(:last_name) %></th>
          <th><%= sortable contact_people, :email, t(:email) %></th>
          <th><%= sortable contact_people, :phone, t(:phone) %></th>
          <th style="width: 80px;"></th>
        </tr>
      </thead>
      <tbody>
        <% contact_people.each do |person| %>
          <tr style="cursor: pointer;" onclick="window.location='<%= edit_hke_contact_person_path(person) %>';">
            <td><%= person.first_name %></td>
            <td><%= person.last_name %></td>
            <td><%= person.email %></td>
            <td><%= person.phone %></td>
            <td onclick="event.stopPropagation();">
              <div style="display: flex; align-items: center; gap: 0.25rem;">
                <%= link_to edit_hke_contact_person_path(person),
                      class: "adm-icon-btn",
                      title: t("action_edit") do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                  </svg>
                <% end %>
                <%= button_to hke_contact_person_path(person),
                      method: :delete,
                      class: "adm-icon-btn adm-icon-btn-danger",
                      title: t("action_delete"),
                      form: { data: { turbo_confirm: t("are_you_sure") } } do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                  </svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div style="padding: 2rem; text-align: center; color: var(--adm-muted); font-size: 22px;">
      <%= params[:name_search].present? ? "לא נמצאו תוצאות לחיפוש" : "אין אנשי קשר" %>
    </div>
  <% end %>
</div>

<% if pagy.pages > 1 %>
  <div class="adm-pagination">
    <%== pagy.series_nav %>
  </div>
<% end %>
