<div class="adm-page">

  <%= render "hke/shared/page_header",
        title: t('contact_people'),
        action_html: link_to(t("shared.scaffold.new.title", model: t("contact_person")),
                             new_hke_contact_person_path,
                             class: "adm-btn adm-btn-primary") %>

  <%= form_with url: hke_contact_people_path, method: :get,
        data: { turbo_frame: "contacts_results" },
        class: "adm-search-bar" do |form| %>
    <%= form.search_field :name_search,
          value: params[:name_search],
          placeholder: t('search_by_first_or_last_name'),
          class: "adm-search-input",
          oninput: "this.form.requestSubmit();",
          onsearch: "this.form.requestSubmit();" %>
    <div class="adm-per-page-wrap">
      <span class="adm-per-page-label">שורות בעמוד:</span>
      <%= form.select :per_page,
            [10, 25, 50, 100],
            { selected: @per_page },
            { class: "adm-per-page-select", onchange: "this.form.requestSubmit();" } %>
    </div>
    <%= form.hidden_field :sort, value: params[:sort] %>
    <%= form.hidden_field :direction, value: params[:direction] %>
  <% end %>

  <turbo-frame id="contacts_results">
    <%= render "results",
          contact_people: @contact_people,
          pagy: @pagy,
          total_contacts: @total_contacts %>
  </turbo-frame>

</div>
