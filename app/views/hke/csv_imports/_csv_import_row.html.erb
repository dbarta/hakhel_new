<tr id="<%= dom_id(csv_import) %>" class="hover:bg-gray-50">
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <%= csv_import.name.presence || t('csv_imports.index.unnamed', default: 'ללא שם') %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <%= csv_import.user.name %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <%= csv_import.created_at.strftime('%b %d, %H:%M') %>
  </td>
  <td class="px-6 py-4 text-sm text-right">
    <% case csv_import.status %>
    <% when 'pending' %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
        <%= t('csv_imports.statuses.pending', default: 'ממתין') %>
      </span>
    <% when 'processing' %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
        <%= t('csv_imports.statuses.processing', default: 'בעיבוד') %>
      </span>
    <% when 'completed' %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
        <%= t('csv_imports.statuses.completed', default: 'הושלם') %>
      </span>
    <% when 'failed' %>
      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
        <%= t('csv_imports.statuses.failed', default: 'נכשל') %>
      </span>
    <% end %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <%= csv_import.total_rows %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <% if csv_import.failed_rows > 0 %>
      <span class="text-red-600 font-medium"><%= csv_import.failed_rows %></span>
    <% else %>
      <span class="text-gray-500">0</span>
    <% end %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <%= csv_import.total_deceased_in_input %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <%= csv_import.total_contacts_in_input %>
  </td>
  <td class="px-6 py-4 text-sm text-gray-900 text-right">
    <span class="text-green-600 font-medium"><%= csv_import.new_deceased %></span> /
    <span class="text-blue-600 font-medium"><%= csv_import.existing_deceased %></span>
  </td>
  <td class="px-6 py-4 text-sm text-right">
    <% if csv_import.processing? || csv_import.completed? %>
      <div class="flex items-center gap-2">
        <div class="flex-1 bg-gray-200 rounded-full h-2">
          <div class="bg-blue-600 h-2 rounded-full transition-all duration-300"
               style="width: <%= csv_import.progress_percentage %>%"></div>
        </div>
        <span class="text-xs text-gray-600 whitespace-nowrap">
          <%= csv_import.progress_percentage %>%
        </span>
      </div>
    <% else %>
      <span class="text-xs text-gray-500">-</span>
    <% end %>
  </td>
  <td class="px-6 py-4 text-sm text-right">
    <div class="flex items-center justify-end gap-4">
      <%= link_to t('csv_imports.index.view', default: 'צפה'), hke_csv_import_path(csv_import),
          class: "text-blue-600 hover:text-blue-800 font-medium" %>
      <%= link_to t('csv_imports.index.delete', default: 'מחק'), hke_csv_import_path(csv_import),
          class: "text-red-600 hover:text-red-800 font-medium",
          data: {
            turbo_method: :delete,
            turbo_confirm: t('csv_imports.index.confirm_delete', default: 'למחוק את הלוג הזה?')
          } %>
    </div>
  </td>
</tr>
