<div class="container mx-auto p-4" style="direction: rtl;">
  <div class="max-w-6xl mx-auto">
    <div class="bg-white rounded-lg shadow-sm p-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between mb-6">
        <h1 class="text-2xl font-bold text-right flex-1"><%= t('csv_imports.index.title', default: 'פעולות העלאת נתונים') %></h1>
	        <% if @csv_imports.any? %>
          <div class="flex flex-row gap-3" style="direction: ltr;">
	            <%= link_to t('csv_imports.index.clear_all', default: 'מחק את כל הלוגים'), destroy_all_hke_csv_imports_path,
                class: "px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700 whitespace-nowrap",
                data: {
                  turbo_method: :delete,
                  turbo_confirm: t('csv_imports.index.clear_all_confirm', default: 'למחוק את כל הלוגים?')
                } %>
	            <%= link_to t('csv_imports.index.new_import', default: 'יבוא חדש'), new_hke_csv_import_path,
                class: "px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700 whitespace-nowrap ml-2" %>
          </div>
        <% end %>
      </div>

      <%= turbo_stream_from "hke_csv_imports" %>
      <% if @csv_imports.any? %>
        <div class="overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.run_name', default: 'שם הריצה') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.uploaded_by', default: 'הועלה על ידי') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.uploaded_at', default: 'תאריך העלאה') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.status', default: 'סטטוס') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.total_input_rows', default: 'סה״כ שורות') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.error_rows', default: 'שורות שגיאה') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.deceased_input', default: 'נפטרים בקלט') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.contacts_input', default: 'אנשי קשר בקלט') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.new_vs_existing', default: 'חדש / קיים') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.progress', default: 'התקדמות') %>
                </th>
                <th class="px-6 py-3 text-right text-xs font-medium text-gray-700 uppercase tracking-wider">
                  <%= t('csv_imports.index.actions', default: 'פעולות') %>
                </th>
              </tr>
            </thead>
            <tbody class="bg-white divide-y divide-gray-200">
              <%= render partial: "csv_import_row", collection: @csv_imports, as: :csv_import %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="text-center py-12">
          <p class="text-gray-500 mb-4"><%= t('csv_imports.index.no_imports', default: 'אין יבואים עדיין') %></p>
	          <%= link_to t('csv_imports.index.create_first', default: 'צור יבוא ראשון'), new_hke_csv_import_path,
              class: "inline-block px-4 py-2 bg-blue-600 text-white rounded-md text-sm font-medium hover:bg-blue-700" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

