
<div class="container mx-auto p-4" style="direction: rtl;"
     data-controller="poller"
     data-poller-active-value="<%= @csv_import.pending? || @csv_import.processing? %>"
     data-poller-interval-value="3000">
  <div class="max-w-4xl mx-auto">
    <%= render partial: "csv_import", locals: { csv_import: @csv_import } %>
  </div>
</div>
