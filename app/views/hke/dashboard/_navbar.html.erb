<%
  # Determine context: system admin overview vs community admin
  dash_system_admin = current_user.system_admin? && session[:selected_community_id].blank?
  dash_community    = !dash_system_admin
%>

<nav class="adm-nav">

  <%# ── Start (right in RTL): brand + nav links ── %>
  <div class="adm-nav-start">
    <%= link_to "הקהל", dash_system_admin ? hke_admin_root_path : hke_root_path,
                class: "adm-nav-brand" %>

    <% if dash_community && (comm = current_community) %>
      <div class="adm-nav-community">
        <% if comm.logo.attached? %>
          <%= image_tag comm.logo, class: "adm-nav-community-logo", alt: comm.name %>
        <% end %>
        <% if comm.website_url.present? %>
          <%= link_to comm.name, comm.website_url, target: "_blank", rel: "noopener",
                      class: "adm-nav-community-name", data: { turbo_prefetch: "false" } %>
        <% else %>
          <span class="adm-nav-community-name"><%= comm.name %></span>
        <% end %>
      </div>
    <% end %>

    <div class="adm-nav-links">
      <% if dash_system_admin %>
        <%= link_to t("admin.dashboard.management.communities"), hke_admin_communities_path, data: { turbo_prefetch: "false" } %>
        <%= link_to t("admin.dashboard.management.users"),       hke_users_path,             data: { turbo_prefetch: "false" } %>
        <%= link_to t("admin.dashboard.management.system_preferences"), hke_system_preferences_path, data: { turbo_prefetch: "false" } %>
        <%= link_to t("admin.advanced.title", default: "כלים מתקדמים"), hke_admin_advanced_path, data: { turbo_prefetch: "false" } %>
      <% else %>
        <%# Community admin links %>
        <div class="adm-nav-dropdown">
          <button class="adm-nav-dropdown-trigger">
            הודעות
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
          <div class="adm-nav-dropdown-menu">
            <%= link_to t("community_admin.navbar.message_approval"),   hke_root_path,                      data: { turbo_prefetch: "false" } %>
            <%= link_to t("community_admin.navbar.message_management"), hke_message_management_index_path, data: { turbo_prefetch: "false" } %>
          </div>
        </div>
        <%= link_to t("community_admin.navbar.deceased_people"), hke_deceased_people_path,        data: { turbo_prefetch: "false" } %>
        <%= link_to t("community_admin.navbar.contact_people"),  hke_contact_people_path,         data: { turbo_prefetch: "false" } %>
        <%= link_to t("community_admin.navbar.import_csv"),      hke_csv_imports_path,            data: { turbo_prefetch: "false" } %>
        <%= link_to t("community_admin.navbar.preferences"),     hke_community_preferences_path,  data: { turbo_prefetch: "false" } %>
      <% end %>
    </div>
  </div>

  <%# ── End (left in RTL): community switcher + user ── %>
  <div class="adm-nav-end">

    <% if dash_system_admin %>
      <div class="adm-nav-switcher">
        <%= form_with url: hke_admin_switch_to_community_path, method: :post, local: true do |f| %>
          <%= f.select :community_id,
              options_from_collection_for_select(Hke::Community.order(:name), :id, :name, nil),
              { prompt: t("admin.dashboard.community_switching.switch_to_community") },
              { dir: "rtl", autocomplete: "off", onchange: "this.form.submit();" } %>
        <% end %>
      </div>
    <% elsif dash_community %>
      <%# Back to system admin link if the current user is a system admin %>
      <% if current_user.system_admin? %>
        <%= form_with url: hke_admin_switch_to_community_path, method: :post, local: true do |f| %>
          <%= f.hidden_field :community_id, value: "" %>
          <%= f.submit t("admin.dashboard.community_switching.back_to_system_admin"),
              class: "adm-nav-links" %>
        <% end %>
      <% end %>
    <% end %>

    <%# User section %>
    <div class="adm-nav-user-wrap">
      <div class="adm-nav-user">
        <div class="adm-avatar">
          <%= [current_user.first_name.to_s[0], current_user.last_name.to_s[0]].join.upcase %>
        </div>
        <%= current_user.name.presence || current_user.email %>
      </div>

      <div class="adm-user-dropdown">
        <%= link_to t("profile"), profile_hke_users_path, data: { turbo_prefetch: "false" } %>
        <% if current_user.system_admin? %>
          <%= link_to t("community_admin.navbar.logs", default: "לוגים"), hke_logs_path, data: { turbo_prefetch: "false" } %>
        <% end %>
        <%= link_to t("logout"), main_app.destroy_user_session_path,
            data: { turbo_method: :delete, turbo_confirm: t("are_you_sure") } %>
      </div>
    </div>

  </div>
</nav>
