<div data-controller="modal">

  <%# Modal overlay — sits inside the controller so actions resolve correctly %>
  <div data-modal-target="overlay"
       class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50"
       id="preview_modal"
       data-action="click->modal#backdropClose">
    <div class="bg-white rounded-lg shadow-xl w-full max-w-lg mx-4">
      <turbo-frame id="message_preview_frame">
        <%# Filled lazily when a preview link is clicked %>
      </turbo-frame>
    </div>
  </div>

  <div class="container mx-auto p-4" style="direction: rtl;">
    <div class="max-w-5xl mx-auto">

      <div class="flex items-center justify-between mb-6">
        <h1 class="text-2xl font-bold"><%= t('community_admin.dashboard.message_approval.title') %></h1>
      </div>

      <%# Time filter %>
      <div class="flex gap-2 mb-4">
        <% [['one_week', 'שבוע קרוב'], ['two_weeks', 'שבועיים'], ['one_month', 'חודש'], ['all', 'הכל']].each do |value, label| %>
          <%= link_to label,
              approve_hke_future_messages_path(time_filter: value),
              class: "px-3 py-1 rounded text-sm font-medium border #{@time_filter == value ? 'bg-blue-600 text-white border-blue-600' : 'bg-white text-gray-600 border-gray-300 hover:bg-gray-50'}" %>
        <% end %>
      </div>

      <% if @messages.any? %>
        <div class="flex gap-3 mb-4">
          <%= button_to t('community_admin.dashboard.message_approval.approve_all', default: 'אשר הכל'),
              approve_all_hke_future_messages_path(time_filter: @time_filter),
              method: :post,
              class: "px-4 py-2 bg-green-600 text-white rounded text-sm font-medium hover:bg-green-700" %>
          <%= button_to t('community_admin.dashboard.message_approval.disapprove_all', default: 'בטל אישור הכל'),
              disapprove_all_hke_future_messages_path(time_filter: @time_filter),
              method: :post,
              class: "px-4 py-2 bg-yellow-500 text-white rounded text-sm font-medium hover:bg-yellow-600" %>
        </div>
      <% end %>

      <div id="messages_table" class="bg-white rounded-lg shadow-sm">
        <%= render partial: "hke/future_messages/messages_approval_table",
                   locals: { messages: @messages } %>
      </div>

    </div>
  </div>

</div>
