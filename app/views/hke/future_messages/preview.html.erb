<turbo-frame id="message_preview_frame">
  <div style="direction: rtl;">
    <div data-action="mousedown->draggable#dragStart"
         style="display: flex; justify-content: space-between; align-items: center;
                padding: 1rem 1.25rem; border-bottom: 1px solid #e2ded8;
                cursor: grab; user-select: none; background: #f5f4f0; border-radius: 12px 12px 0 0;">
      <span style="font-size: 22px; font-weight: 600; color: #1a1a1a;">תצוגת הודעה</span>
      <button type="button"
              data-action="click->modal#close"
              style="font-size: 28px; line-height: 1; color: #9ca3af; background: none; border: none; cursor: pointer;">&times;</button>
    </div>
    <div style="padding: 1.25rem; background: #ffffff; border-radius: 0 0 12px 12px;">
      <div style="background: #f9f8f6; border-radius: 8px; padding: 1.25rem; font-size: 22px; color: #1a1a1a; white-space: pre-wrap; line-height: 1.7; font-family: 'Heebo', sans-serif;"><%=
        CGI.escapeHTML(@preview_text)
           .gsub(/(https?:\/\/[^\s]+)/) { |url| "<a href=\"#{url}\" target=\"_blank\" style=\"color:#1d4ed8; text-decoration:underline; word-break:break-all;\">#{url}</a>" }
           .html_safe
      %></div>
    </div>
  </div>
</turbo-frame>
