<div class="overflow-x-auto">
  <% if messages.any? %>
    <table class="min-w-full">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t('message_management.table.sent_at') %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t('message_management.table.recipient') %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t('message_management.table.method') %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t('message_management.table.status') %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t('message_management.table.message_preview') %>
          </th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">
            <%= t('actions') %>
          </th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% messages.each do |message| %>
          <tr class="hover:bg-gray-50">
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
              <%= message.created_at.in_time_zone(current_community&.preference&.time_zone.presence || "Jerusalem").strftime("%b %d, %Y %H:%M") %>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
              <div>
                <% if message.respond_to?(:phone) && message.phone.present? %>
                  <div class="font-medium"><%= message.phone %></div>
                <% end %>
                <% if message.respond_to?(:email) && message.email.present? %>
                  <div class="text-gray-500"><%= message.email %></div>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900 text-right">
              <% if message.respond_to?(:delivery_method) %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium
                  <%= message.delivery_method == 'sms' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800' %>">
                  <%= message.delivery_method&.upcase %>
                </span>
              <% else %>
                <span class="text-gray-500">-</span>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-right">
              <%
                ds = message.delivery_status.presence
                badge_class = case ds
                  when "delivered"               then "bg-green-100 text-green-800"
                  when "sent"                    then "bg-blue-100 text-blue-800"
                  when "sending"                 then "bg-blue-50 text-blue-600"
                  when "queued"                  then "bg-gray-100 text-gray-600"
                  when "undelivered", "failed"   then "bg-red-100 text-red-800"
                  when "bounced", "blocked"      then "bg-orange-100 text-orange-800"
                  when "unsubscribed"            then "bg-purple-100 text-purple-800"
                  else                                "bg-gray-100 text-gray-400"
                end
                label = ds ? t("message_management.delivery_statuses.#{ds}", default: ds) \
                           : t("message_management.delivery_statuses.unknown")
                error_code = message.twilio_error_code.presence
                hint = error_code ? t("message_management.remediation.#{error_code}",
                         default: t("message_management.remediation.default")) : nil
              %>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= badge_class %>">
                <%= label %>
              </span>
              <% if hint %>
                <div class="mt-1 text-xs text-red-600 max-w-[160px] leading-tight">
                  <% if error_code %><span class="font-medium">(<%= error_code %>)</span> <% end %><%= hint %>
                </div>
              <% end %>
            </td>
            <td class="px-6 py-4 text-sm text-gray-900 text-right">
              <div class="max-w-xs">
                <% if message.is_a?(Hke::SentMessage) && message.full_message.present? %>
                  <%= truncate(message.full_message, length: 100) %>
                <% else %>
                  <span class="text-gray-500">-</span>
                <% end %>
              </div>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-right">
              <div class="flex flex-col gap-1 items-end">
                <%= link_to t('show'),
                    hke_message_management_path(message),
                    class: "text-blue-600 hover:text-blue-900" %>
                <%
                  contact = message.messageable&.contact_person rescue nil
                %>
                <% if message.delivery_bounced? && contact %>
                  <%= link_to t('message_management.table.fix_email'),
                      edit_hke_contact_person_path(contact),
                      class: "text-orange-600 hover:text-orange-900 text-xs" %>
                <% end %>
                <% if %w[undelivered failed].include?(message.delivery_status) &&
                      %w[30005 30006].include?(message.twilio_error_code.to_s) && contact %>
                  <%= link_to t('message_management.table.fix_phone'),
                      edit_hke_contact_person_path(contact),
                      class: "text-orange-600 hover:text-orange-900 text-xs" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-8 text-gray-500">
      <%= t('message_management.index.no_messages') %>
    </div>
  <% end %>
</div>
