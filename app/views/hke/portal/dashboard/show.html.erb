<%# Portal Dashboard %>

<div style="display: flex; flex-direction: column; gap: 1.5rem;">

  <%# Header greeting %>
  <div style="display: flex; align-items: baseline; gap: 0.5rem; flex-wrap: wrap;">
    <h1 style="font-family: var(--font-serif); font-size: 1.75rem; color: var(--color-navy); margin: 0;">
      שלום, <%= @contact.first_name %>
    </h1>
    <span style="color: var(--color-gold); font-size: 1.1rem;">✡</span>
  </div>

  <%# Quick links %>
  <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem;">
    <%= link_to portal_profile_path(@portal_token), class: "portal-card", style: "text-align: center; text-decoration: none; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; padding: 1rem;" do %>
      <svg viewBox="0 0 24 24" style="width: 1.6rem; height: 1.6rem; stroke: var(--color-navy); fill: none; stroke-width: 1.5;"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
      <span style="font-size: 0.82rem; color: var(--color-navy); font-weight: 500;">פרופיל שלי</span>
    <% end %>
    <%= link_to portal_preferences_path(@portal_token), class: "portal-card", style: "text-align: center; text-decoration: none; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; padding: 1rem;" do %>
      <svg viewBox="0 0 24 24" style="width: 1.6rem; height: 1.6rem; stroke: var(--color-navy); fill: none; stroke-width: 1.5;"><line x1="4" y1="6" x2="20" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/><circle cx="9" cy="6" r="2" fill="white" stroke="var(--color-navy)"/><circle cx="15" cy="12" r="2" fill="white" stroke="var(--color-navy)"/><circle cx="9" cy="18" r="2" fill="white" stroke="var(--color-navy)"/></svg>
      <span style="font-size: 0.82rem; color: var(--color-navy); font-weight: 500;">העדפות</span>
    <% end %>
    <%= link_to portal_venues_path(@portal_token), class: "portal-card", style: "text-align: center; text-decoration: none; display: flex; flex-direction: column; align-items: center; gap: 0.4rem; padding: 1rem;" do %>
      <svg viewBox="0 0 24 24" style="width: 1.6rem; height: 1.6rem; stroke: var(--color-gold); fill: none; stroke-width: 1.5;"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
      <span style="font-size: 0.82rem; color: var(--color-navy); font-weight: 500;">שירותים</span>
    <% end %>
  </div>

  <%# Deceased relations section %>
  <% if @relations.any? %>
    <section>
      <div class="section-heading">
        <span>🕯️</span> הנפטרים שלי
      </div>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.875rem;">
        <% @relations.each do |relation| %>
          <% dp = relation.deceased_person %>
          <% fm = relation.future_messages.first %>
          <div class="portal-card" style="display: flex; flex-direction: column; gap: 0.6rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <div>
                <div style="font-family: var(--font-serif); font-size: 1.05rem; font-weight: 500; color: var(--color-navy);">
                  <%= dp.first_name %> <%= dp.last_name %>
                </div>
                <div style="font-size: 0.8rem; color: var(--color-warm-gray); margin-top: 0.15rem;">
                  <%= t("hke.relations.relation_types.#{relation.relations_selections.first&.selection&.relation_type}", default: "") rescue "" %>
                </div>
              </div>
              <a href="#" style="font-size: 0.75rem; color: var(--color-navy); text-decoration: none; padding: 0.25rem 0.6rem; border: 1px solid var(--color-border); border-radius: 6px; display: flex; align-items: center; gap: 0.3rem;">
                <svg viewBox="0 0 24 24" style="width: 0.85rem; height: 0.85rem; stroke: currentColor; fill: none; stroke-width: 2;"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                ערוך
              </a>
            </div>

            <% if fm.present? %>
              <div style="background: #f5f0e8; border-radius: 8px; padding: 0.6rem 0.75rem; font-size: 0.82rem;">
                <div style="color: var(--color-warm-gray); margin-bottom: 0.2rem;">יארצייט הבא</div>
                <div style="color: var(--color-navy); font-weight: 500;">
                  <%= l(fm.send_date, format: :long) rescue fm.send_date.strftime("%d/%m/%Y") %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  <% else %>
    <div class="portal-card" style="text-align: center; color: var(--color-warm-gray); padding: 2rem;">
      אין נפטרים מקושרים לחשבון זה
    </div>
  <% end %>

  <%# Upcoming messages %>
  <% upcoming = @relations.flat_map { |r| r.future_messages }.select { |m| m.send_date >= Date.today }.sort_by(&:send_date).first(5) %>
  <% if upcoming.any? %>
    <section>
      <div class="section-heading">
        <span>📬</span> הודעות קרובות
      </div>
      <div class="portal-card" style="padding: 0; overflow: hidden;">
        <% upcoming.each_with_index do |msg, i| %>
          <div style="display: flex; align-items: center; gap: 0.75rem; padding: 0.85rem 1.25rem; <%= i > 0 ? 'border-top: 1px solid var(--color-border);' : '' %>">
            <div style="font-size: 1.2rem;">
              <%= msg.delivery_method == "email" ? "✉️" : msg.delivery_method == "whatsapp" ? "💬" : "📱" %>
            </div>
            <div style="flex: 1;">
              <div style="font-size: 0.9rem; color: var(--color-navy);">
                <%= msg.messageable.deceased_person.first_name %> <%= msg.messageable.deceased_person.last_name %>
              </div>
              <div style="font-size: 0.78rem; color: var(--color-warm-gray);">
                <%= l(msg.send_date, format: :long) rescue msg.send_date.strftime("%d/%m/%Y") %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

</div>
