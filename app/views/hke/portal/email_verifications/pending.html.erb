<%# Portal — Verification email sent %>
<div style="display: flex; flex-direction: column; gap: 1.25rem; text-align: center;">
  <div style="font-size: 3rem;">📧</div>
  <h1 style="font-family: var(--font-serif); font-size: 1.5rem; color: var(--color-navy); margin: 0;">
    <%= t("hke.portal.email_verification.pending_title") %>
  </h1>
  <div class="portal-card">
    <p style="color: var(--color-navy); font-size: 0.95rem; line-height: 1.6;">
      <%= t("hke.portal.email_verification.pending_body", email: @pending_email) %>
    </p>
  </div>
  <%= link_to "חזור לדף הבית", portal_dashboard_path(@portal_token), class: "btn-outline" %>
</div>
