<%# Portal Venues %>
<style>
  .venue-card {
    border-radius: 14px;
    overflow: hidden;
    background: white;
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }
  .venue-card-header {
    padding: 1.75rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    color: white;
  }
  .venue-card-header .icon { font-size: 1.8rem; }
  .venue-card-header .title {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    font-weight: 700;
    color: white;
    text-align: center;
  }
  .venue-card-body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    flex: 1;
  }
  .venue-card-body .desc {
    font-size: 0.875rem;
    color: var(--color-warm-gray);
    line-height: 1.65;
    flex: 1;
  }
  .btn-venue {
    display: block;
    width: 100%;
    text-align: center;
    padding: 0.6rem 1rem;
    border-radius: 8px;
    border: 1.5px solid var(--color-gold);
    color: var(--color-gold);
    background: transparent;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    text-decoration: none;
  }
  .btn-venue:hover { background: var(--color-gold); color: white; }
</style>

<div style="display: flex; flex-direction: column; gap: 1.5rem;">
  <div>
    <h1 style="font-family: var(--font-serif); font-size: 1.5rem; color: var(--color-navy); margin: 0 0 0.25rem;">שירותי הקהילה</h1>
    <p style="font-size: 0.875rem; color: var(--color-warm-gray); margin: 0;">דרכים נוספות לכבד את זכר הנפטר</p>
  </div>

  <% if @venues.any? %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem;">
      <% @venues.each do |venue| %>
        <% already_requested = @submitted_venue_ids.include?(venue.id) %>
        <div class="venue-card">
          <div class="venue-card-header" style="background: linear-gradient(135deg, #1e3a5f, #2a4f7f);">
            <span class="icon">
              <%= venue.venue_type == "kaddish" ? "🕍" : venue.venue_type == "seudah" ? "🍽️" : "📖" %>
            </span>
            <div class="title"><%= venue.title %></div>
          </div>
          <div class="venue-card-body">
            <div class="desc"><%= venue.description %></div>
            <div>
              <% if already_requested %>
                <div style="display: flex; align-items: center; justify-content: center; gap: 0.4rem; color: var(--color-sage); font-size: 0.875rem; font-weight: 500;">
                  <svg viewBox="0 0 24 24" style="width: 1rem; height: 1rem; stroke: currentColor; fill: none; stroke-width: 2.5;"><polyline points="20 6 9 17 4 12"/></svg>
                  הבקשה נשלחה
                </div>
              <% else %>
                <%= form_with url: portal_venue_request_path(@portal_token, venue_id: venue.id), method: :post, local: true do |f| %>
                  <%= f.submit "בקש", class: "btn-venue" %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <%# Demo venues — shown until real CommunityVenue records exist %>
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem;">
      <div class="venue-card">
        <div class="venue-card-header" style="background: linear-gradient(135deg, #1a3a5c, #253f6b);">
          <span class="icon">🕍</span>
          <div class="title">אמירת קדיש</div>
        </div>
        <div class="venue-card-body">
          <div class="desc">לא יכולים להגיע לבית הכנסת? ניתן לבקש מהקהילה שיאמרו קדיש לעילוי נשמת הנפטר.</div>
          <div><a href="#" class="btn-venue">בקש קדיש</a></div>
        </div>
      </div>

      <div class="venue-card">
        <div class="venue-card-header" style="background: linear-gradient(135deg, #5c3a1a, #7a4f28);">
          <span class="icon">🍽️</span>
          <div class="title">סעודת מצווה</div>
        </div>
        <div class="venue-card-body">
          <div class="desc">ארגן סעודת מצווה לכבוד הנפטר — ביום היארצייט, בשבוע שחל בו, או בשבת הסמוכה.</div>
          <div><a href="#" class="btn-venue">בקש סעודת מצווה</a></div>
        </div>
      </div>

      <div class="venue-card">
        <div class="venue-card-header" style="background: linear-gradient(135deg, #1a4a2e, #265c3a);">
          <span class="icon">📖</span>
          <div class="title">לימוד לעילוי נשמה</div>
        </div>
        <div class="venue-card-body">
          <div class="desc">בקש לימוד משנה או גמרא לעילוי נשמת הנפטר ביום היארצייט בבית הכנסת.</div>
          <div><a href="#" class="btn-venue">בקש לימוד לזכר</a></div>
        </div>
      </div>
    </div>
  <% end %>
</div>
