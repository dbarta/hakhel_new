<% if items.count > 0 %>
  <div
    class="
      bg-white rounded shadow table-responsive text-sm text-right text-gray-700
    "
  >
    <table class="table border border-grey-500">
      <thead>
        <tr>
          <% fields.each do |field| %>
            <% field_translation = t(field.to_s).presence || "ERROR" %>
            <% if field_translation == "ERROR" %>
            <% end %>
            <th class="p-2">
              <%= sortable items, field, field_translation %>
            </th>
          <% end %>
          <% other_fields.each do |field| %>
            <th class="p-2"><%= field[:header] %></th>
          <% end %>
          <th class="w-20 p-3 uppercase"><%= t("shared.scaffold.actions") %></th>
        </tr>
      </thead>
      <tbody class="text-base">
        <% items.each do |item| %>
          <% edit_item_path =
            case item.class.name
            when "Hke::DeceasedPerson"
              edit_hke_deceased_person_path(item)
            when "Hke::ContactPerson"
              edit_hke_contact_person_path(item)
            when "Hke::Community"
              edit_hke_admin_community_path(item)
            when "User"
              edit_hke_user_path(item)
            else
              "#"
            end %>
          <tr
            class="border-t border-gray-400 group hover:bg-gray-100"
            onclick="window.location='<%= edit_item_path %>';"
          >
            <% fields.each do |field| %>
              <% value = item.send(field) %>
              <td class="p-2 ">
                <% if value.is_a?(Date) || value.is_a?(Time) || value.is_a?(ActiveSupport::TimeWithZone) %>
                  <%= value.strftime("%d-%m-%Y") %>
                <% else %>
                  <%= value %>
                <% end %>
              </td>
            <% end %>

            <% other_fields.each do |field| %>
              <td class="p-2 "><%= item.send field[:data] %></td>
            <% end %>
            <td class="flex items-center gap-1" onclick="event.stopPropagation();">
              <% actions.each do |action| %>
                <% is_delete = action[:name] == "action_delete" %>
                <% action_path = send(action[:path], item) %>
                <% if is_delete %>
                  <%= button_to action_path,
                  method: :delete,
                  class: "p-1 rounded hover:bg-gray-100 text-red-500 hover:text-red-700",
                  title: t(action[:name]),
                  form: { data: { turbo_confirm: action[:confirm] ? t("are_you_sure") : nil } } do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  <% end %>
                <% else %>
                  <%= link_to action_path,
                  class: "p-1 rounded hover:bg-gray-100 text-gray-500 hover:text-gray-800",
                  title: t(action[:name]) do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                  <% end %>
                <% end %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
